{
  "SpecificationVersion": 1,
  "Author": "",
  "AppName": "Echoes of Elysium",
  "SupportedPlatforms": ["Windows", "Linux"],
  "DefaultIPBinding": "0.0.0.0",
  "DefaultMaxUsers": 6,
  "Settings": {
    "ServerName": {
      "ReadableName": "Server Name",
      "Description": "The name displayed in the in-game server browser.",
      "Category": "Server Settings",
      "Keywords": "name",
      "InputType": "text",
      "DefaultValue": "Echoes of Elysium",
      "Placeholder": "My Elysium Server",
      "MaxLength": 64,
      "EnumValues": {}
    },
    "ServerPassword": {
      "ReadableName": "Server Password",
      "Description": "Password to join this server. Leave empty for a public server.",
      "Category": "Server Settings",
      "Keywords": "password private",
      "InputType": "password",
      "DefaultValue": "",
      "MaxLength": 64,
      "EnumValues": {}
    },
    "SaveFrequency": {
      "ReadableName": "Save Frequency (minutes)",
      "Description": "How often the world is auto-saved.",
      "Category": "World",
      "Keywords": "save autosave",
      "InputType": "number",
      "DefaultValue": "5",
      "Suffix": "min",
      "EnumValues": {}
    },
    "BackupsEnabled": {
      "ReadableName": "Enable Backups",
      "Description": "Enable automatic world backups.",
      "Category": "World",
      "Keywords": "backup",
      "InputType": "checkbox",
      "DefaultValue": "true",
      "CheckedValue": "true",
      "UncheckedValue": "false",
      "EnumValues": {}
    },
    "BackupsFrequency": {
      "ReadableName": "Backup Frequency (minutes)",
      "Description": "How often a world backup is created.",
      "Category": "World",
      "Keywords": "backup frequency",
      "InputType": "number",
      "DefaultValue": "30",
      "Suffix": "min",
      "EnumValues": {}
    },
    "MaxBackups": {
      "ReadableName": "Max Backups to Keep",
      "Description": "Maximum number of backup files retained.",
      "Category": "World",
      "Keywords": "backup max",
      "InputType": "number",
      "DefaultValue": "5",
      "EnumValues": {}
    },
    "SteamChannel": {
      "ReadableName": "Steam Release Channel",
      "Description": "Steam branch used for server updates.",
      "Category": "Advanced",
      "Keywords": "steam branch update channel",
      "InputType": "enum",
      "DefaultValue": "public",
      "EnumValues": {
        "public": "Public (Stable)",
        "prerelease": "Prerelease"
      }
    },
    "ProfileEnabled": {
      "ReadableName": "Enable Runtime Profiling",
      "Description": "Enable performance profiling (debugging only).",
      "Category": "Advanced",
      "Keywords": "profile debug performance",
      "InputType": "checkbox",
      "DefaultValue": "false",
      "CheckedValue": "true",
      "UncheckedValue": "false",
      "EnumValues": {}
    }
  }
}
